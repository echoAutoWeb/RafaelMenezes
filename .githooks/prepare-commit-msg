#!/bin/sh
# Auto-fill commit message when none provided.
# Usage: git config core.hooksPath .githooks

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

if [ -z "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

# If message already contains non-whitespace, do nothing
MSG_CONTENT=$(cat "$COMMIT_MSG_FILE" 2>/dev/null || true)
if [ -n "$(echo "$MSG_CONTENT" | tr -d '[:space:]')" ]; then
  exit 0
fi

cat > "$COMMIT_MSG_FILE" <<'EOF'
Atualiza seção Conheça nossa estrutura: reordena cidades, adiciona troca por clique e justifica texto
EOF

exit 0
